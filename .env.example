# =============================================
# tl;dv → Notion → LINE 自動化 環境変数設定
# =============================================
# このファイルをコピーして .env として使用してください
# cp .env.example .env

# --- サーバー設定 ---
PORT=3000

# --- tl;dv ---
# tl;dvダッシュボード > Settings > Integrations > Webhooks で設定するシークレット
# 設定しない場合は署名検証をスキップします
TLDV_WEBHOOK_SECRET=

# --- Notion ---
# https://www.notion.so/my-integrations でインテグレーションを作成してAPIキーを取得
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 録画を保存するデータベースのID
# NotionデータベースのURLから取得: https://www.notion.so/workspace/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Anthropic (Claude API) ---
# https://console.anthropic.com でAPIキーを取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- LINE Notify ---
# https://notify-bot.line.me/my/ でトークンを発行
# ※ グループLINEでLINE Notifyを友達追加し、グループに招待してからトークン発行すること
LINE_NOTIFY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
